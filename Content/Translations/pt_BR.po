msgctxt "xmas99/01_xmas1"
msgid ""
"\n"
"You can buttstomp through\n"
"some of the weakspots\n"
"in the pathways!"
msgstr ""
"\n"
"Você pode dar bundadas\n"
"em alguns pontos fracos\n"
"nos caminhos!"

