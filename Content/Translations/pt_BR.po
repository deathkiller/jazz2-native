msgctxt "xmas99/01_xmas1"
msgid ""
"\n"
"Some blocks can only\n"
"be broken with a\n"
"certain weapon."
msgstr ""
"\n"
"Alguns blocos só podem\n"
"ser quebrados usando\n"
"uma arma específica."

