msgctxt "xmas99/01_xmas1"
msgid ""
"\n"
"Welcome to Christmas Chronicles!"
msgstr ""
"\n"
"Bem vindo ao Christmas Chronicles!"

#: .fake/Translations/xmas99/01_xmas1.j2l.h:5
msgctxt "xmas99/01_xmas1"
msgid ""
"\n"
"Seasons Greetings from\n"
"Epic MegaGames\n"
"Orange Games and\n"
"Project 2 Interactive!"
