msgctxt "share/03_share3"
msgid ""
"\n"
"You made it! This is the end\n"
" of the shareware version.\n"
"Now check out the order info\n"
"for M O R E!"
msgstr ""
"\n"
"Você conseguiu! Esse é o fim\n"
" da versão de testes.\n"
"Cheque a versão completa\n"
"para MUITO MAIS!"

