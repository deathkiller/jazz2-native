"\f[c:#704a4a]Verbinding is verbroken!\f[/c]\n"
"\n"
"\n"
"De server wordt afgesloten.\n"
"Probeer het later opnieuw."

#: Sources/Main.cpp:1187
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down for maintenance.\n"
"Please try it again later."
msgstr ""
"\f[c:#704a4a]Verbinding is verbroken!\f[/c]\n"
"\n"
"\n"
"De server wordt afgesloten voor onderhoud.\n"
"Probeer het later opnieuw."

