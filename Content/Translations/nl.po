"\f[c:#704a4a]Kan geen verbinding maken met de server!\f[/c]\n"
"\n"
"\n"
"De server zit vol.\n"
"Probeer het later opnieuw."

#: Sources/Main.cpp:1185
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Server is not in a state where it can process your request.\n"
"Please try again in a few seconds."
msgstr ""
"\f[c:#704a4a]Kan geen verbinding maken met de server!\f[/c]\n"
"\n"
"\n"
"De server is niet in een staat waarin je verzoek kan worden verwerkt.\n"
"Probeer het over enkele seconden opnieuw."

#: Sources/Main.cpp:1186
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down.\n"
"Please try it later."
