msgid ""
"\n"
"Welcome to Burrowsville\n"
"Please drive carefully."
msgstr ""
"\n"
"Benvenuti a Burrowsville\n"
"Si prega di guidare con prudenza."

#: .fake/Translations/xmas99/03_xmas3.j2l.h:4
msgctxt "xmas99/03_xmas3"
msgid ""
"\n"
"That bridge doesnt\n"
