msgctxt "xmas99/03_xmas3"
msgid ""
"\n"
"Robert and Craig:\n"
"Springs RULE! :)"
msgstr ""
"\n"
"Robert e Craig:\n"
"Le molle REGNANO! :)"

#: .fake/Translations/xmas99/03_xmas3.j2l.h:6
msgctxt "xmas99/03_xmas3"
msgid ""
"\n"
"Now leaving Burrowsville\n"
"Please visit again."
msgstr ""
"\n"
"In partenza da Burrowsville\n"
"Vi invitiamo a tornare a trovarci."

#: .fake/Translations/xmas99/03_xmas3.j2l.h:7
msgctxt "xmas99/03_xmas3"
msgid ""
"\n"
"Password: xmasbunny\n"
"Please visit\n"
"www.project2.com"
msgstr ""
"\n"
"Password: xmasbunny\n"
"Prego visita\n"
"www.project2.com"

