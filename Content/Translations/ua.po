"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down for maintenance.\n"
"Please try it again later."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ВИМИКАЄТЬСЯ ДЛЯ ТЕХНІЧНОГО ОБСЛУГОВУВАННЯ.\n"
"СПРОБУЙТЕ ЩЕ РАЗ ПІЗНІШЕ."

#: Sources/Main.cpp:1188
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down for reconfiguration.\n"
"Please try it again later."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ВИМИКАЄТЬСЯ ДЛЯ РЕКОНФІГУРАЦІЇ.\n"
"СПРОБУЙТЕ ЩЕ РАЗ ПІЗНІШЕ."

#: Sources/Main.cpp:1189
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down for update.\n"
"Please check your client version and try it again in a minute."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ВИМИКАЄТЬСЯ ДЛЯ ОНОВЛЕННЯ.\n"
"ПЕРЕВІРТЕ ВЕРСІЮ ЦЬОГО КЛІЄНТУ ТА СПРОБУЙТЕ ЩЕ РАЗ ЧЕРЕЗ ХВИЛИНУ."

#: Sources/Main.cpp:1190
msgid ""
"\f[c:#704a4a]Connection has been lost!\f[/c]\n"
"\n"
"\n"
"Please try it again and if the problem persists,\n"
"check your network connection."
msgstr ""
"\f[c:#704a4a]ЗВ'ЯЗОК З СЕРВЕРОМ ВТРАЧЕНО!\f[/c]\n"
"\n"
"\n"
"СПРОБУЙТЕ ЩЕ РАЗ, І ЯКЩО ПРОБЛЕМА НЕ ЗНИКНЕ,\n"
"ПЕРЕВІРТЕ ІНТЕРНЕТ З'ЄДНАННЯ."

#: Sources/Main.cpp:1191
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"The server is not responding for connection request."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР НЕ ВІДПОВІДАЄ НА ЗАПИТИ ПІДКЛЮЧЕННЯ."

#: Sources/Main.cpp:1192
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"You have been \f[c:#907050]kicked\f[/c] off the server.\n"
"Contact server administrators for more information."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"ВИ БУЛИ \f[c:#907050]ВИГНАНІ\f[/c] З СЕРВЕРА.\n"
"ЗВЕРНІТЬСЯ ДО АДМІНІСТРАТОРІВ СЕРВЕРУ ДЛЯ ОТРИМАННЯ ДОДАТКОВОЇ ІНФОРМАЦІЇ."

#: Sources/Main.cpp:1193
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"You have been \f[c:#725040]banned\f[/c] off the server.\n"
"Contact server administrators for more information."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"ВИ БУЛИ \f[c:#725040]ЗАБЛОКОВАНІ\f[/c] НА СЕРВЕРІ.\n"
"ЗВЕРНІТЬСЯ ДО АДМІНІСТРАТОРІВ СЕРВЕРУ ДЛЯ ОТРИМАННЯ ДОДАТКОВОЇ ІНФОРМАЦІЇ."

#: Sources/Main.cpp:1194
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Cheating detected."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"ВИЯВЛЕНО ЧІТИ."

#: Sources/Main.cpp:1195
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Your client doesn't contain required assets.\n"
"Please download the required files and try it again."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"ВАШ КЛІЄНТ НЕ МІСТИТЬ НЕОБХІДНИХ РЕСУРСІВ.\n"
"ЗАВАНТАЖТЕ НЕОБХІДНІ ФАЙЛИ ТА СПРОБУЙТЕ ЩЕ РАЗ."

#: Sources/Main.cpp:1196
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"The server has disconnected you due to inactivity."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
