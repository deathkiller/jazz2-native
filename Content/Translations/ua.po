"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"ВКАЗАНО НЕДІЙСНИЙ ПАРОЛЬ."

#: Sources/Main.cpp:1181
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Invalid player name specified.\n"
"Please check your profile and try it again."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"ВКАЗАНО НЕДІЙСНЕ ІМ'Я ГРАВЦЯ.\n"
"ПЕРЕВІРТЕ СВІЙ ПРОФІЛЬ ТА СПРОБУЙТЕ ЩЕ РАЗ."

#: Sources/Main.cpp:1182
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"This client is not in the server whitelist.\n"
"Contact server administrators for more information."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"ЦЕЙ КЛІЕНТ НЕ ВХОДИТЬ ДО БІЛОГО СПИСКУ СЕРВЕРА.\n"
"ЗВЕРНІТЬСЯ ДО АДМІНІСТРАТОРІВ СЕРВЕРУ ДЛЯ ОТРИМАННЯ ДОДАТКОВОЇ ІНФОРМАЦІЇ."

#: Sources/Main.cpp:1183
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Server requires 3rd party authentication provider.\n"
"Contact server administrators for more information."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ВИМАГАЄ ВИКОРИСТАННЯ СТОРОННЬОГО ПОСТАЧАЛЬНИКА АУТЕНТИФІКАЦІЇ.\n"
"ЗВЕРНІТЬСЯ ДО АДМІНІСТРАТОРІВ СЕРВЕРУ ДЛЯ ОТРИМАННЯ ДОДАТКОВОЇ ІНФОРМАЦІЇ."

#: Sources/Main.cpp:1184
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Server capacity is full.\n"
"Please try it later."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ПЕРЕПОВНЕНИЙ.\n"
"СПРОБУЙТЕ ПІЗНІШЕ."

#: Sources/Main.cpp:1185
msgid ""
"\f[c:#704a4a]Cannot connect to the server!\f[/c]\n"
"\n"
"\n"
"Server is not in a state where it can process your request.\n"
"Please try again in a few seconds."
msgstr ""
"\f[c:#704a4a]НЕМОЖЛИВО ПІДКЛЮЧИТИСЯ ДО СЕРВЕРУ!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР НЕ МОЖЕ ОБРОБИТИ ВАШ ЗАПИТ НА ДАНИЙ МОМЕНТ.\n"
"СПРОБУЙТЕ ЩЕ РАЗ ЧЕРЕЗ КІЛЬКА СЕКУНД."

#: Sources/Main.cpp:1186
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Server is shutting down.\n"
"Please try it later."
msgstr ""
"\f[c:#704a4a]З'ЄДНАННЯ БУЛО ЗАКРИТО!\f[/c]\n"
"\n"
"\n"
"СЕРВЕР ВИМИКАЄТЬСЯ.\n"
"СПРОБУЙТЕ ПІЗНІШЕ."

#: Sources/Main.cpp:1187
