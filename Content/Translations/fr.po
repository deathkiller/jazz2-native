msgid ""
"\n"
"Shoot these blocks!"
msgstr ""
"\n"
"Tire sur ces dalles !"

#: .fake/Translations/share/01_share1.j2l.h:2
msgctxt "share/01_share1"
msgid ""
"\n"
"When in the air, press down\n"
"to stomp with your butt."
msgstr ""
"\n"
"Quand tu es en l'air, appuie sur Bas\n"
"pour taper avec ton derrière."

