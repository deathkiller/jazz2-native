#: .fake/Translations/secretf/08_town2.j2l.h:1
msgctxt "secretf/08_town2"
msgid ""
"\n"
"Find the crate and the gems are yours!"
msgstr ""
"\n"
"Trouvez le coffre et les joyaux seront à vous !"

