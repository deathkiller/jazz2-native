msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"You have been \f[c:#725040]banned\f[/c] off the server.\n"
"Contact server administrators for more information."
msgstr ""
"\f[c:#704a4a]СОЕДИНЕНИЕ БЫЛО ЗАКРЫТО!\f[/c]\n"
"\n"
"\n"
"ВЫ \f[c:#725040]ЗАБАНЕНЫ\f[/c] НА СЕРВЕРЕ.\n"
"СВЯЖИТЕСЬ С АДМИНИСТРАТОРАМИ СЕРВЕРА ЧТОБЫ ПОЛУЧИТЬ БОЛЬШЕ ИНФОРМАЦИИ."

#: Sources/Main.cpp:1194
msgid ""
"\f[c:#704a4a]Connection has been closed!\f[/c]\n"
"\n"
"\n"
"Cheating detected."
