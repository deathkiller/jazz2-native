"\n"
"Robert and Craig:\n"
"Springs RULE! :)"
msgstr ""
"\n"
"Robert y Craig:\n"
"¡Los trampolines son lo MÁXIMO! :)"

#: .fake/Translations/xmas99/03_xmas3.j2l.h:6
msgctxt "xmas99/03_xmas3"
msgid ""
"\n"
"Now leaving Burrowsville\n"
"Please visit again."
msgstr ""
"\n"
"Abandonando Burrowsville\n"
"Visítanos de nuevo."

#: .fake/Translations/xmas99/03_xmas3.j2l.h:7
msgctxt "xmas99/03_xmas3"
