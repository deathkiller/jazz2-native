"\n"
"¡Algunos cajones tienen\n"
"bombas y personajes malos!"

#: .fake/Translations/share/02_share2.j2l.h:1
msgctxt "share/02_share2"
msgid ""
"\n"
"You need twenty coins to pass \n"
"through this secret warp!"
msgstr ""
"\n"
"¡Necesitas veinte monedas para pasar por \n"
"esta ventana secreta!"

