msgctxt "xmas99/02_xmas2"
msgid ""
"\n"
"Punching the blocks above you\n"
"can be rewarding."
msgstr ""
"\n"
"Golpear los bloques que están encima tuyo\n"
"puede ser gratificante."

#: .fake/Translations/xmas99/02_xmas2.j2l.h:6
msgctxt "xmas99/02_xmas2"
msgid ""
"\n"
"Gem Trail Entry Crate."
msgstr ""
"\n"
"Cajón de entrada para sendero de gemas."

